# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=gamecollector
POSTGRES_PASSWORD=password
POSTGRES_DB=gamecollector

# ─── Backend ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=gamecollector
DB_PASSWORD=password
DB_NAME=gamecollector

